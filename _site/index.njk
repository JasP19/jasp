---
layout: layouts/page-home.njk
hero: /images/header.png
eleventyNavigation:
  key: main
---

{% set postslist = collections.posts | head(11) %}
{% set reviewlist = collections.reviews | head(7) %}

<head>  
  <title>jasp</title>
  <meta charset="utf-8">
  <meta name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no'>
  <meta name='description' content='A tech blog featuring coding, electronics and gaming'/>
  <meta property='og:title' content='jasp' />
  <meta property='og:type' content='website' />
  <meta property='og:description' content='A tech blog featuring coding, electronics and gaming'/>
  <meta property='og:url' content='https://jasp.dev' />
  <meta property='og:image' content='/images/preview.png'/>
  <meta property='twitter:image' content='https://jasp.dev/images/preview.png'/>
</head>

<div class="row">
  <div class="main-content col-md-9">
    <h4 class="family-sans text-primary mt-2 mb-4 px-3 px-sm-0">Latest Posts</h4>
    {%- for item in postslist %}
    {% include "includes/items.njk" %}
    {% endfor -%}
  </div>
  <div class="main-sidebar col-md-3">
    <h4 class="text-primary mt-2 mb-4 px-3 px-sm-0">Latest Reviews</h4>
    {% set itemList = reviewlist %}
    {% for item in itemList %}
    {% include "includes/sidebar.njk" %}
    {% endfor -%}
  </div>
</div>
